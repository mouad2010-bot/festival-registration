<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

    <%- include("partials/head") %>

</head>

<body>

<section class="login-page">

<div class="login-box">

<h1>

تسجيل دخول الإدارة

</h1>

<% if(error){ %>

<div class="message error">

<%= error %>

</div>

<% } %>

<form

action="/auth/login"

method="POST">

<div class="form-group">

<label>

اسم المستخدم

</label>

<input

type="text"

name="username"

required>

</div>

<div class="form-group">

<label>

كلمة المرور

</label>

<input

type="password"

name="password"

required>

</div>

<button type="submit">

تسجيل الدخول

</button>

</form>

</div>

</section>

</body>

</html>