<!DOCTYPE html>

<html lang="ar" dir="rtl">

<head>

<%- include("partials/head") %>

</head>

<body>

<section class="success-page">

<div class="container">

<div class="ticket">

<div class="ticket-header">

<h1>

تم التسجيل بنجاح

</h1>

<p>

أهلاً بك في مهرجان هويات الدولي

</p>

</div>

<div class="ticket-body">

<div class="ticket-grid">

<div class="ticket-info">

<p>

<strong>

الاسم:

</strong>

<%= participant.fullName %>

</p>

<p>

<strong>

البريد:

</strong>

<%= participant.email %>

</p>

<p>

<strong>

الهاتف:

</strong>

<%= participant.phone %>

</p>

<p>

<strong>

المدينة:

</strong>

<%= participant.city %>

</p>

<p>

<strong>

رقم التذكرة:

</strong>

<%= participant.ticketId %>

</p>

</div>

<div class="qr-area">

<img

src="<%= participant.qrCode %>"

alt="QR Code">

</div>

</div>

<div class="ticket-buttons">

<button

id="printTicket">

طباعة

</button>

<button

id="downloadTicket">

تحميل

</button>

<a

href="/">

الرئيسية

</a>

</div>

</div>

</div>

</div>

</section>

<script src="/js/app.js"></script>

</body>

</html>