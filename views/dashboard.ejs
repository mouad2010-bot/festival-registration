<!DOCTYPE html>

<html lang="ar" dir="rtl">

<head>

<%- include("partials/head") %>

</head>

<body>

<%- include("partials/navbar") %>

<section class="dashboard">

<div class="container">

<h1 class="section-title">

لوحة التحكم

</h1>

<!-- ===================================== -->

<div class="stats-grid">

<div class="dashboard-card">

<h2>

<%= total %>

</h2>

<p>

إجمالي المسجلين

</p>

</div>

<div class="dashboard-card">

<h2>

<%= remaining %>

</h2>

<p>

المقاعد المتبقية

</p>

</div>

<div class="dashboard-card">

<h2>

<%= used %>

</h2>

<p>

دخلوا المهرجان

</p>

</div>

</div>

<!-- ===================================== -->

<div class="search-box">

<input

type="text"

placeholder="بحث...">

<a

class="btn btn-export"

href="/admin/export">

تصدير CSV

</a>

<a

class="btn btn-view"

href="/qr">

ماسح QR

</a>

<div class="dashboard-actions">

    <a href="/auth/change-account" class="settings-btn">

        ⚙️ الإعدادات

    </a>

    <a href="/auth/logout" class="logout-btn">

        تسجيل الخروج

    </a>

</div>

</div>

<!-- ===================================== -->

<div class="table-wrapper">

<table>

<thead>

<tr>

<th>

#

</th>

<th>

الاسم

</th>

<th>

المدينة

</th>

<th>

الهاتف

</th>

<th>

Ticket ID

</th>

<th>

الحالة

</th>

<th>

الإجراءات

</th>

</tr>

</thead>

<tbody>

<% participants.forEach(participant=>{ %>

<tr>

<td>

<%= participant.id %>

</td>

<td>

<%= participant.fullName %>

</td>

<td>

<%= participant.city %>

</td>

<td>

<%= participant.phone %>

</td>

<td>

<%= participant.ticketId %>

</td>

<td>

<% if(participant.used){ %>

✅ مستخدمة

<% }else{ %>

🟢 جديدة

<% } %>

</td>

<td>

<a

class="btn btn-view"

href="/admin/participant/<%= participant.id %>">

عرض

</a>

<form

style="display:inline"

action="/admin/delete/<%= participant.id %>"

method="POST">

<button

class="btn btn-delete delete-btn"

type="submit">

حذف

</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</section>

<script src="/js/app.js"></script>

</body>

</html>