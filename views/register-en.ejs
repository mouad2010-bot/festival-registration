<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

    <%- include("partials/head") %>

</head>

<body>

<%- include("partials/navbar") %>

<section class="register-page">

<div class="container">

<div class="register-container">

<h1 class="register-title">

Registration for the International Festival of Identities

</h1>

<p class="text-center mb-20">

Registration is free and the number of participants is limited to 500.

</p>

<!-- ========================= -->

<% if(error){ %>

<div class="message error">

<%= error %>

</div>

<% } %>

<!-- ========================= -->

<div class="message warning">

Remaining seats:

<strong>

<%= remainingSeats %>

</strong>

</div>

<!-- ========================= -->

<form

action="/register"

method="POST"

class="register-form"

>

<input
type="hidden"
name="lang"
value="en">

<div class="form-group">

<label>

full name

</label>

<input

type="text"

name="fullName"

required>

</div>

<!-- ========================= -->

<div class="form-group">

<label>

e-mail

</label>

<input

type="email"

name="email"

required>

</div>

<!-- ========================= -->

<div class="form-group">

<label>

phone number

</label>

<input

type="tel"

name="phone"

required>

</div>

<!-- ========================= -->

<div class="form-group">

<label>

City

</label>

<input

type="text"

name="city"

required>

</div>

<!-- ========================= -->

<div class="form-group">

<label>

age

</label>

<input

type="number"

name="age"

min="5"

max="100"

required>

</div>

<!-- ========================= -->

<div class="form-group">

<label>

Gender

</label>

<select

name="gender"

required>

<option value="">

Choose

</option>

<option>

male

</option>

<option>

female

</option>

</select>

</div>

<!-- ========================= -->

<div class="form-group full">

<label>

I agree to the use of my data
for the sole purpose of organizing the festival.

</label>

<input

required

type="checkbox">

</div>

<!-- ========================= -->

<div
class="cf-turnstile"
data-sitekey="0x4AAAAAADvMpj-ppH8xh3sc">
</div>

<br>

<button

class="submit-btn"

type="submit">

Free registration

</button>

<script
src="https://challenges.cloudflare.com/turnstile/v0/api.js"
async
defer>
</script>

</form>

</div>

</div>

</section>

<%- include("partials/footer") %>

<script src="/js/app.js"></script>

</body>

</html>